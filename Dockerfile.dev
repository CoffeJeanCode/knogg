FROM rust:1-bookworm

WORKDIR /app

RUN apt-get update && apt-get install -y \
    pkg-config \
    libxcb1-dev \
    libxkbcommon-dev \
    mingw-w64 \
    && rm -rf /var/lib/apt/lists/*

# Windows cross-compile target.
RUN rustup target add x86_64-pc-windows-gnu && \
    rustup component add rustfmt clippy

CMD ["bash"]
